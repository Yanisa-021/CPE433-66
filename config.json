{
    "DocumentRoot": ".",
    "Port": "8080",
    "ThreadingMode": "Single",
    "Plugins": [
        {
            "Path": "stat",
            "Class": "DNWS.StatPlugin",
            "Preprocessing": "true",
            "Postprocessing": "false"
        },
        {
            "Path": "ox",
            "Class": "DNWS.OXPlugin",
            "Preprocessing": "false",
            "Postprocessing": "false"
        },
        {
            "Path": "delay",
            "Class": "DNWS.DelayPlugin",
            "Preprocessing": "false",
            "Postprocessing": "false"
        },
        {

            "Path": "clientinfo",
            "Class": "DNWS.ClientInfoPlugin",
            "Preprocessing": "true",
            "Postprocessing": "false"
        }
    ]
}

